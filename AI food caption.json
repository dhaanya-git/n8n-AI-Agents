      "parameters": {
        "jsCode": "const dish = $json.dish_name;\nconst desc = $json.description;\nconst platform = $json.platform;\nconst price = $json.price;\nconst tone = $json.tone;\n\nconst prompt = `\nYou are a restaurant marketing expert.\n\nGenerate:\n1. Instagram caption\n2. Facebook caption\n3. Google Business post\n4. 10 hashtags\n5. Best posting time\n\nDish Name: ${dish}\nDescription: ${desc}\nPlatform: ${platform}\nPrice: ${price}\nTone: ${tone}\n\nMake the output attractive and engaging.\n`;\n\nreturn [\n  {\n    json: {\n      prompt: prompt\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
