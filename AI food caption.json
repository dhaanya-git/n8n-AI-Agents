        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama-3.1-8b-instant\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are a restaurant loyalty marketing AI.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Generate a personalized loyalty message for {{$json.customer_name}} who is a {{$json.messageType}} customer. Tier: {{$json.tier}}. Points: {{$json.points}}.\"\n    }\n  ],\n  \"temperature\": 0.8\n}",
