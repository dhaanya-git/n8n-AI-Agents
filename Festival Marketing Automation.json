    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst prompt = `\nYou are an expert restaurant marketing AI.\n\nCreate a complete festival marketing campaign.\n\nRestaurant Details:\nRestaurant Name: ${data.restaurant_name}\nCity: ${data.city}\nCuisine: ${data.cuisine}\nFestival: ${data.festival}\nTarget Audience: ${data.target_audience}\nAverage Budget Per Customer: ₹${data.avg_budget}\nKitchen Capacity: ${data.kitchen_capacity}\nOffer Budget: ₹${data.offer_budget}\n\nGenerate:\n1. Festival theme\n2. Catchy tagline\n3. 5 special menu items\n4. Offer ideas\n5. Instagram promotion plan for 7 days\n6. 3 WhatsApp promotional texts\n7. Table booking CTA\n8. Decoration idea\n\nMake the output professional and attractive.\n`;\n\nreturn [\n  {\n    json: {\n      prompt: prompt\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        416,
        0
      ],
      "id": "b6b701d3-bea5-4f33-b7fb-252d806fd353",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
