      "retryOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const aiReply = $json.choices[0].message.content;\n\nconst lowerReply = aiReply.toLowerCase();\n\nlet sentiment = \"Positive\";\nlet escalation = \"No\";\n\nif (\n  lowerReply.includes(\"sorry\") ||\n  lowerReply.includes(\"apologize\") ||\n  lowerReply.includes(\"apology\") ||\n  lowerReply.includes(\"regret\")\n) {\n  sentiment = \"Negative\";\n}\n\nif (\n  lowerReply.includes(\"refund\") ||\n  lowerReply.includes(\"urgent\") ||\n  lowerReply.includes(\"manager\") ||\n  lowerReply.includes(\"compensation\")\n) {\n  escalation = \"Yes\";\n}\n\nreturn {\n  ai_response: aiReply,\n  sentiment: sentiment,\n  escalation: escalation\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        0
      ],
      "id": "cf9a28f2-1242-40b0-93a9-42f29ef87dfa",
      "name": "Code in JavaScript",
      "retryOnFail": true,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const rating = $json.rating;\nconst review = $json.review_text;\nconst customer = $json.customer_name;\nconst platform = $json.platform;\n\nlet instruction = \"\";\n\nif (rating >= 4) {\n  instruction = \"Generate a warm and friendly thank-you reply for this restaurant review.\";\n} else {\n  instruction = \"Generate a professional apology reply for this negative restaurant review. Sound empathetic and human.\";\n}\n\nreturn {\n  prompt: `\nCustomer Name: ${customer}\nPlatform: ${platform}\nRating: ${rating}\nReview: ${review}\n\n${instruction}\n\nKeep the reply short and professional.\n`\n};"
      },
